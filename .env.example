# Скопируйте этот файл в .env и подставьте свои данные.
# .env в .gitignore — реальные значения не попадут в репозиторий.
#
# Нумерация серверов: 1 — без суффикса, далее 2, 3, ...
# Команды берут сервер по флагу --server N.

# --- Сервер 1 ---
Address=YOUR_SERVER_IP
Port=22
User=root
Password=YOUR_SSH_PASSWORD
DNS=example.com

# --- Сервер 2 (опционально) ---
# Address2=YOUR_SECOND_SERVER_IP
# Port2=22
# User2=root
# Password2=YOUR_SSH_PASSWORD
# DNS2=example2.com
